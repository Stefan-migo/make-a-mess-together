{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "AGENTS.md",
    "PLAN.md",
    "DESIGN.md"
  ],
  "agent": {
    "cortex-planner": {
      "mode": "primary",
      "model": "anthropic/claude-sonnet-4-20250514",
      "temperature": 0.3,
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "deny"
        },
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "webfetch": "allow",
        "skill": "allow",
        "task": { "*": "allow" }
      }
    },
    "cortex-developer": {
      "mode": "primary",
      "model": "anthropic/claude-sonnet-4-20250514",
      "temperature": 0.2,
      "permission": {
        "edit": "allow",
        "bash": "allow",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "todowrite": "allow",
        "skill": "allow",
        "task": { "*": "allow" }
      }
    }
  },
  "mcp": {
    "engram": {
      "type": "local",
      "command": ["engram", "mcp"],
      "enabled": true,
      "_note": "Persistent Hippocampus memory. 19 tools: mem_save, mem_search, mem_judge, session lifecycle, FTS5 search."
    },
    "graphify": {
      "type": "local",
      "command": ["python3", "-m", "graphify.serve", "wiki/graph/graph.json"],
      "enabled": true,
      "_note": "Parietal lobe: codebase knowledge graph for structural understanding before editing."
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
      "_note": "Documentation search for 30+ libraries (React, Next.js, Tailwind, etc.)."
    },
    "github": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-github"],
      "enabled": true,
      "environment": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "{env:GITHUB_TOKEN}"
      },
      "_note": "GitHub PR, issue, and code management. Set GITHUB_TOKEN in .env.local and source it before launching OpenCode."
    }
  },
  "permission": {
    "skill": {
      "*": "allow"
    }
  }
}
